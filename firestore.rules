rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Helpers de Autenticación y Roles
     */
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * Gestión de Roles Globales
     */
    match /roles_admin/{adminId} {
      allow get: if true;
      allow read, write: if false; 
    }

    /**
     * Anuncios del Sistema
     */
    match /system/announcements {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * Estructura Multi-Tenant
     * Bloque principal para los datos de cada taller/negocio
     */
    match /users/{userId} {
      // Permitimos lectura y escritura al dueño del negocio o al administrador global
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      /**
       * Subcolecciones (sale_transactions, products, repair_jobs, workers, etc.)
       * Aplicamos la misma lógica de propiedad a todos los datos anidados.
       */
      match /{allData=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }
  }
}